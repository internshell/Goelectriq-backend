


# Google OAuth Configuration (Required for Google Sign-In)
# Get these from https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Go to Credentials and create OAuth 2.0 Client ID for Web application
# 4. Add authorized redirect URIs:
#    - http://localhost:5000
#    - https://yourdomain.com (for production)
# 5. Add authorized JavaScript origins:
#    - http://localhost:3000
#    - http://localhost:5173
#    - https://yourdomain.com (for production)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Server API Key (Required for backend Distance Matrix/Geocoding calls)
GOOGLE_SERVER_KEY=your_google_server_api_key_here

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_or_app_password

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret



# SMS Service (Optional)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=GOELEC

# WhatsApp Cloud API Configuration (Meta/Facebook)
# Get these from Meta Business Platform: https://business.facebook.com/
# 1. Create a WhatsApp Business Account
# 2. Set up a WhatsApp Business App
# 3. Generate access token with 'whatsapp_business_messaging' permission
# API URL format: https://graph.instagram.com/v17.0 (or latest version)
WHATSAPP_API_URL=https://graph.instagram.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Admin WhatsApp Number (for notifications)
# Format: country_code+phone_number (e.g., +919876543210)
ADMIN_PHONE=+919876543210